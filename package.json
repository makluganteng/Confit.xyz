{
  "name": "confit-xyz",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run --workspace=apps/web dev",
    "dev:risk": "npm run --workspace=apps/risk-service dev",
    "build": "npm run --workspace=apps/web build",
    "db:push": "npm run --workspace=apps/web db:push",
    "db:generate": "npm run --workspace=apps/web db:generate",
    "test": "jest --config jest.config.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6"
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "@solana-program/memo": "^0.11.0",
    "@solana/kit": "^6.3.1",
    "@wallet-standard/app": "^1.1.0",
    "@walletconnect/universal-provider": "^2.23.8",
    "react-device-detect": "^2.2.3",
    "ws": "^8.19.0"
  }
}
